# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/rental-marketplace

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-key
JWT_REFRESH_EXPIRE=30d

# Email Configuration (Optional - for production)
EMAIL_SERVICE=gmail
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@rentalmarketplace.com

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Payment Gateway Configuration (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Payment Gateway Configuration (Cashfree)
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_WEBHOOK_SECRET=your_cashfree_webhook_secret

# KYC Service Configuration
KYC_PROVIDER=signzy
SIGNZY_API_KEY=your_signzy_api_key
SIGNZY_API_SECRET=your_signzy_api_secret
HYPERVERGE_APP_ID=your_hyperverge_app_id
HYPERVERGE_APP_KEY=your_hyperverge_app_key

# Delivery Service Configuration
BORZO_API_KEY=your_borzo_api_key
DUNZO_CLIENT_ID=your_dunzo_client_id
DUNZO_CLIENT_SECRET=your_dunzo_client_secret
PORTER_API_KEY=your_porter_api_key

# Commission Rates (percentage)
RENTAL_COMMISSION_RATE=20
SALE_COMMISSION_RATE=15
SERVICE_FEE_MIN=200
SERVICE_FEE_MAX=500
SERVICE_FEE_DEFAULT=300

# Geofencing Configuration
HYPERLOCAL_RADIUS_KM=15
EXPRESS_DELIVERY_TIME_MINUTES=90

# Subscription Configuration
STYLE_PASS_BASIC_PRICE=2999
STYLE_PASS_PREMIUM_PRICE=5999
STYLE_PASS_ELITE_PRICE=9999

# Insurance Configuration
INSURANCE_PROVIDER=bajaj_allianz
INSURANCE_API_KEY=your_insurance_api_key

# Dry Cleaning Service
FABKLEAN_API_KEY=your_fabklean_api_key

# SMS Service (for OTP)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# AWS S3 (for image uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=rental-marketplace-uploads

# Google Maps API (for geolocation)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key